# Environment Variables Template
# Copy this file to .env and customize for your environment
# Note: .env is in .gitignore and will not be committed

# ============================================
# Kafka Configuration
# ============================================

# Kafka bootstrap servers
# For local development: localhost:9092
# For Docker container: kafka:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Kafka topics
KAFKA_TOPIC_RAW=ticks.raw
KAFKA_TOPIC_FEATURES=ticks.features

# Kafka consumer group (optional override)
KAFKA_CONSUMER_GROUP=crypto-volatility-consumer

# Kafka session timeout (milliseconds)
KAFKA_SESSION_TIMEOUT_MS=30000

# Kafka heartbeat interval (milliseconds)
KAFKA_HEARTBEAT_INTERVAL_MS=10000

# Maximum records per poll
KAFKA_MAX_POLL_RECORDS=100

# Producer acknowledgment level (all, 1, 0)
KAFKA_ACKS=all

# Maximum in-flight requests per connection
KAFKA_MAX_IN_FLIGHT_REQUESTS=1

# ============================================
# MLflow Configuration
# ============================================

# MLflow tracking URI
# For local: http://localhost:5001
# For Docker: http://mlflow:5000
MLFLOW_TRACKING_URI=http://localhost:5001

# MLflow experiment name (optional override)
# MLFLOW_EXPERIMENT_NAME=crypto-volatility-detection

# ============================================
# Coinbase WebSocket Configuration
# ============================================

# WebSocket URL (default in config.yaml)
# COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com

# Trading pairs to monitor (comma-separated)
# COINBASE_SYMBOLS=BTC-USD,ETH-USD

# ============================================
# Model Configuration
# ============================================

# Model variant: ml (Random Forest) or baseline (rule-based fallback)
# Use baseline for quick rollback during ML model issues
MODEL_VARIANT=ml

# Volatility spike threshold (0.041799 = 95th percentile)
MODEL_SPIKE_THRESHOLD=0.041799

# Model file path (optional override)
# MODEL_PATH=models/artifacts/random_forest_model.pkl

# ============================================
# Feature Engineering Configuration
# ============================================

# Feature window sizes in seconds
FEATURE_WINDOW_SHORT=30
FEATURE_WINDOW_MEDIUM=60
FEATURE_WINDOW_LONG=120

# ============================================
# Data Storage Configuration
# ============================================

# Data directory paths (optional overrides)
# DATA_RAW_DIR=data/raw
# DATA_PROCESSED_DIR=data/processed

# ============================================
# FastAPI Configuration
# ============================================

# API server host
API_HOST=0.0.0.0

# API server port
API_PORT=8000

# API version
API_VERSION=1.0.0

# Enable debug mode (true/false)
API_DEBUG=false

# Enable API documentation (true/false)
API_DOCS_ENABLED=true

# CORS allowed origins (comma-separated, or * for all)
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# API request timeout (seconds)
API_REQUEST_TIMEOUT=30

# ============================================
# Resilience Configuration
# ============================================

# Circuit breaker failure threshold
CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker timeout (seconds)
CIRCUIT_BREAKER_TIMEOUT=60

# Exponential backoff initial delay (seconds)
BACKOFF_INITIAL_DELAY=1

# Exponential backoff maximum delay (seconds)
BACKOFF_MAX_DELAY=60

# Maximum retry attempts
MAX_RETRY_ATTEMPTS=10

# Kafka producer retry attempts
KAFKA_RETRY_ATTEMPTS=3

# ============================================
# Monitoring Configuration
# ============================================

# Prometheus metrics port
METRICS_PORT=9090

# Enable metrics collection (true/false)
METRICS_ENABLED=true

# Metrics export interval (seconds)
METRICS_EXPORT_INTERVAL=15

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format (json, text)
LOG_FORMAT=json

# Log file path (leave empty for stdout only)
LOG_FILE_PATH=logs/app.log

# Enable log rotation (true/false)
LOG_ROTATION_ENABLED=true

# ============================================
# Production/Development Mode
# ============================================

# Environment: development, staging, production
ENVIRONMENT=development

# Number of worker processes (for production)
WORKERS=4

# Worker timeout (seconds)
WORKER_TIMEOUT=30

# ============================================
# Notes
# ============================================
# 
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your specific values
# 3. Never commit .env to git (already in .gitignore)
# 4. Use config.yaml for defaults, .env for overrides
# 5. Environment variables take precedence over config.yaml
