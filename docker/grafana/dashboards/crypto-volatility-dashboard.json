{
  "id": null,
  "uid": "crypto-volatility-api",
  "title": "Crypto Volatility API - Production Monitoring",
  "tags": ["crypto", "api", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "type": "timeseries",
      "title": "API Latency (p50 / p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(predict_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50 (median)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(predict_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 (SLO: 0.8s)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 0.8}
            ]
          },
          "unit": "s"
        }
      },
      "options": {
        "legend": {"calcs": ["mean", "lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 2,
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "type": "timeseries",
      "title": "Error Rate (%)",
      "targets": [
        {
          "expr": "(rate(predict_errors_total[5m]) / rate(predict_requests_total[5m])) * 100",
          "legendFormat": "Error Rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 5
        }
      },
      "options": {
        "legend": {"calcs": ["mean", "lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single"}
      }
    },
    {
      "id": 3,
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 9},
      "type": "timeseries",
      "title": "Data Freshness - Kafka Consumer Lag (messages)",
      "targets": [
        {
          "expr": "kafka_consumer_group_lag_total{consumer_group=\"crypto-volatility-consumer\"}",
          "legendFormat": "Consumer Lag (messages behind)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1000},
              {"color": "orange", "value": 5000},
              {"color": "red", "value": 10000}
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": {"calcs": ["mean", "lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single"}
      }
    }
  ],
  "time": {"from": "now-30m", "to": "now"},
  "timepicker": {"refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m"]}
}
