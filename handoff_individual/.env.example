# Environment Variables Template - Handoff Package
# Copy this file to .env and customize for your environment
# Note: .env is in .gitignore and will not be committed

# ============================================
# Kafka Configuration (Docker Deployment)
# ============================================

# Kafka bootstrap servers
# For Docker container-to-container: kafka:29092
# For local testing: localhost:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Kafka topics
KAFKA_TOPIC_RAW=ticks.raw
KAFKA_TOPIC_FEATURES=ticks.features

# ============================================
# MLflow Configuration (Docker Deployment)
# ============================================

# MLflow tracking URI
# For Docker: http://mlflow:5000
# For local: http://localhost:5001
MLFLOW_TRACKING_URI=http://mlflow:5000

# ============================================
# Model Configuration
# ============================================

# Volatility spike threshold (0.041799 = 95th percentile)
MODEL_SPIKE_THRESHOLD=0.041799

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# Environment Mode
# ============================================

# Environment: development, staging, production
ENVIRONMENT=production

# ============================================
# Quick Start
# ============================================
# 
# 1. Copy this file: cp .env.example .env
# 2. Adjust values if needed (defaults work for Docker)
# 3. Start services: docker compose up -d
# 4. Never commit .env to git
